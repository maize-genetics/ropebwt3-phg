# Output of:  sh docs/examples/run.sh
# Columns (tab-separated):
#   1 qname     query name
#   2 qlen      query length
#   3 status    PLACED | ONE_SIDE | EXACT | UNPLACED
#   4 nCarrier  number of carrier genomes the query was found in
#   5 carriers  carrier sequence names with strand (name:+/-), '.' if none
#   6 refName   reference sequence the query was placed on, '.' if none
#   7 strand    reference strand (+/-)
#   8 cL        reference coordinate of the left breakpoint  ('.' if unknown)
#   9 cR        reference coordinate of the right breakpoint ('.' if unknown)
#  10 refSpan   cR - cL  (reference bases spanned; 0 = clean insertion point)
#  11 insSize   implied inserted size in the carriers (bp)
#
# Ground truth for this example: the insertion sits at the A|B junction =
# reference coordinate 300; the insertion is 500 bp; ref_query was taken from
# reference positions 250..400.

# === default (consensus) mode ===
ins_query	150	PLACED	6	Oh43_chr1:+,B97_chr1:+,CML247_chr1:+,Mo17_chr1:+,Ki3_chr1:+,Tx303_chr1:+	B73_chr1	+	300	300	0	500
ins_query_rc	150	PLACED	6	Oh43_chr1:-,Tx303_chr1:-,B97_chr1:-,Mo17_chr1:-,CML247_chr1:-,Ki3_chr1:-	B73_chr1	-	300	300	0	500
ref_query	150	EXACT	0	.	B73_chr1	+	250	400	150	0
ins_query_1snp	150	PLACED	6	Oh43_chr1:+,B97_chr1:+,CML247_chr1:+,Mo17_chr1:+,Ki3_chr1:+,Tx303_chr1:+	B73_chr1	+	300	300	0	575
unrelated	120	UNPLACED	0	.	.	.	.	.	.	.

# === strict mode (stops at the Ki3 SNP in the left flank -> only the right anchor) ===
ins_query	150	ONE_SIDE	6	Oh43_chr1:+,B97_chr1:+,CML247_chr1:+,Mo17_chr1:+,Ki3_chr1:+,Tx303_chr1:+	B73_chr1	+	.	300	.	.

# === per-carrier mode (one line per carrier; Ki3 places despite its SNP) ===
ins_query	150	PLACED	1	Oh43_chr1:+	B73_chr1	+	300	300	0	500
ins_query	150	PLACED	1	B97_chr1:+	B73_chr1	+	300	300	0	500
ins_query	150	PLACED	1	CML247_chr1:+	B73_chr1	+	300	300	0	500
ins_query	150	PLACED	1	Mo17_chr1:+	B73_chr1	+	300	300	0	500
ins_query	150	PLACED	1	Ki3_chr1:+	B73_chr1	+	300	300	0	500
ins_query	150	PLACED	1	Tx303_chr1:+	B73_chr1	+	300	300	0	500
